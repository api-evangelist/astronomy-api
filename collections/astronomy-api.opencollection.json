          "info": {
            "name": "Search for stars and deep space objects",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.astronomyapi.com/api/v2/search",
            "params": [
              {
                "name": "term",
                "value": "",
                "type": "query"
              },
              {
                "name": "match_type",
                "value": "",
                "type": "query"
              },
              {
                "name": "ra",
                "value": "",
                "type": "query"
              },
              {
                "name": "dec",
                "value": "",
                "type": "query"
              },
              {
                "name": "order_by",
                "value": "",
                "type": "query"
              },
              {
                "name": "limit",
                "value": "",
                "type": "query"
              },
              {
                "name": "offset",
                "value": "",
                "type": "query"
              }
            ],
            "auth": {
              "type": "basic",
              "username": "{{username}}",
              "password": "{{password}}"
            }
          },
          "docs": "Search for stars and deep space objects"
